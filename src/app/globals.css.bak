@import "tailwindcss";

:root {
  --background: #ffffff;
  --foreground: #171717;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-geist-sans);
  --font-mono: var(--font-geist-mono);
}

@media (prefers-color-scheme: dark) {
  :root {
    --background: #0a0a0a;
    --foreground: #ededed;
  }
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: Arial, Helvetica, sans-serif;
}

/* Toolyo premium-but-clean pass */
body {
  background: #f4f4f5;
  color: #111827;
}

.toolyo-card {
  box-shadow: 0 1px 2px rgba(0,0,0,0.04);
}

.toolyo-surface {
  background: #ffffff;
  border: 1px solid #d4d4d8;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

.toolyo-soft {
  background: #fafafa;
  border: 1px solid #d4d4d8;
}

/* Toolyo dark mode */

html.dark body {
  background: #09090b;
  color: #f4f4f5;
}

html.dark .bg-white {
  background-color: #18181b !important;
}

html.dark .bg-zinc-50,
html.dark .bg-zinc-100 {
  background-color: #09090b !important;
}

html.dark .border-zinc-300,
html.dark .border-zinc-200 {
  border-color: #3f3f46 !important;
}

html.dark .text-zinc-950,
html.dark .text-zinc-900 {
  color: #f4f4f5 !important;
}

html.dark .text-zinc-700,
html.dark .text-zinc-600 {
  color: #d4d4d8 !important;
}

html.dark input,
html.dark textarea {
  background-color: #111827 !important;
  color: #f4f4f5 !important;
  border-color: #3f3f46 !important;
}

html.dark input::placeholder,
html.dark textarea::placeholder {
  color: #a1a1aa !important;
}


/* Toolyo theme transitions */
html.theme-transitioning *,
html.theme-transitioning *::before,
html.theme-transitioning *::after {
  transition-property: background-color, border-color, color, fill, stroke, box-shadow, opacity;
  transition-duration: 260ms;
  transition-timing-function: ease;
}

html {
  color-scheme: light;
}

html.dark {
  color-scheme: dark;
}


/* Strong readable text defaults for theme switching */
.dark {
  background-color: #09090b;
}

.dark body {
  background-color: #09090b;
  color: #f8fafc;
}

/* Ad slot readability fix */
.toolyo-ad-label {
  color: #6b7280 !important;
  transition: color 320ms ease;
}

.toolyo-ad-title {
  color: #4b5563 !important;
  transition: color 320ms ease;
}

/* Header pill readability */
.toolyo-header-pill {
  color: #0f172a !important;
  transition: color 320ms ease, background-color 320ms ease, border-color 320ms ease;
}

.dark .toolyo-header-pill {
  color: #ffffff !important;
}


/* =========================
   TOOLYO_THEME_SYSTEM_V2
   ========================= */

:root{

--bg-main:#ffffff;
--bg-card:#ffffff;
--bg-soft:#f6f7fb;

--text-main:#0f172a;
--text-soft:#64748b;

--border-main:#e5e7eb;

--button-bg:#111827;
--button-text:#ffffff;

--input-bg:#ffffff;

}

.dark{

--bg-main:#09090b;
--bg-card:#111114;
--bg-soft:#16161a;

--text-main:#f8fafc;
--text-soft:#9ca3af;

--border-main:#2a2a33;

--button-bg:#ffffff;
--button-text:#000000;

--input-bg:#18181b;

}

/* body */

body{
background:var(--bg-main);
color:var(--text-main);
transition:background-color .35s ease,color .35s ease;
}

/* cards */

.card,
.tool-card,
section{

background:var(--bg-card);
border-color:var(--border-main);
color:var(--text-main);

transition:
background-color .35s ease,
border-color .35s ease,
color .35s ease;

}

/* headings */

h1,h2,h3,h4,h5,h6{
color:var(--text-main);
transition:color .35s ease;
}

/* paragraphs */

p{
color:var(--text-soft);
transition:color .35s ease;
}

/* buttons */

button{

background:var(--button-bg);
color:var(--button-text);
border-color:var(--border-main);

transition:
background-color .35s ease,
color .35s ease,
border-color .35s ease,
transform .25s ease;

}

button:hover{
transform:translateY(-1px);
}

/* inputs */

input,
textarea,
select{

background:var(--input-bg);
color:var(--text-main);
border-color:var(--border-main);

transition:
background-color .35s ease,
color .35s ease,
border-color .35s ease;

}

/* search bar */

input::placeholder{
color:var(--text-soft);
}

/* ad slots */

.toolyo-ad-label{
color:var(--text-soft);
}

.toolyo-ad-title{
color:var(--text-soft);
}

/* smooth global animation */

html.theme-animate *{
transition:
background-color .35s ease,
color .35s ease,
border-color .35s ease,
box-shadow .35s ease;
}







/* TOOLYO_FINAL_THEME_RESET_START */

:root {
  color-scheme: light;

  --toolyo-bg: #f5f5f5;
  --toolyo-surface: #ffffff;
  --toolyo-surface-2: #fafafa;
  --toolyo-text: #111111;
  --toolyo-text-soft: #4b5563;
  --toolyo-text-faint: #6b7280;
  --toolyo-border: #d1d5db;
  --toolyo-input: #ffffff;
  --toolyo-button: #111111;
  --toolyo-button-text: #ffffff;
  --toolyo-pill: #ffffff;
}

html.dark {
  color-scheme: dark;

  --toolyo-bg: #0a0a0a;
  --toolyo-surface: #111111;
  --toolyo-surface-2: #171717;
  --toolyo-text: #f5f5f5;
  --toolyo-text-soft: #d4d4d8;
  --toolyo-text-faint: #a1a1aa;
  --toolyo-border: #3f3f46;
  --toolyo-input: #111111;
  --toolyo-button: #f5f5f5;
  --toolyo-button-text: #111111;
  --toolyo-pill: #111111;
}

html,
body {
  background: var(--toolyo-bg) !important;
  color: var(--toolyo-text) !important;
  transition: background-color 260ms ease, color 260ms ease;
}

body {
  min-height: 100vh;
}

html.theme-animate *,
html.theme-animate *::before,
html.theme-animate *::after {
  transition:
    background-color 260ms ease,
    color 260ms ease,
    border-color 260ms ease,
    box-shadow 260ms ease,
    fill 260ms ease,
    stroke 260ms ease,
    opacity 260ms ease,
    transform 260ms ease !important;
}

/* Base text */
h1, h2, h3, h4, h5, h6,
label, strong, b {
  color: var(--toolyo-text) !important;
}

p, li, small {
  color: var(--toolyo-text-soft) !important;
}

span {
  color: inherit;
}

::placeholder {
  color: var(--toolyo-text-faint) !important;
  opacity: 1;
}

/* Surfaces */
main, section, article, aside, nav, header, footer, div {
  border-color: inherit;
}

header,
nav {
  background-color: var(--toolyo-surface) !important;
  color: var(--toolyo-text) !important;
}

/* Cards / containers */
section,
article,
aside,
div[class*="rounded"],
div[class*="border"],
div[class*="card"],
div[class*="hero"],
div[class*="feature"],
div[class*="tool"],
div[class*="slot"],
div[class*="rail"] {
  border-color: var(--toolyo-border);
}

/* Inputs */
input,
textarea,
select {
  background: var(--toolyo-input) !important;
  color: var(--toolyo-text) !important;
  border-color: var(--toolyo-border) !important;
}

/* Buttons and pills */
button,
a[class*="rounded"],
a[class*="inline-flex"] {
  border-color: var(--toolyo-border) !important;
}

/* DARK MODE overrides for common light classes */
html.dark .bg-white,
html.dark .bg-gray-50,
html.dark .bg-gray-100,
html.dark .bg-neutral-50,
html.dark .bg-neutral-100,
html.dark .bg-zinc-50,
html.dark .bg-zinc-100,
html.dark .bg-slate-50,
html.dark .bg-slate-100 {
  background-color: var(--toolyo-surface) !important;
}

html.dark .text-black,
html.dark .text-gray-900,
html.dark .text-gray-800,
html.dark .text-gray-700,
html.dark .text-neutral-900,
html.dark .text-neutral-800,
html.dark .text-zinc-900,
html.dark .text-zinc-800,
html.dark .text-slate-900,
html.dark .text-slate-800,
html.dark .text-slate-700 {
  color: var(--toolyo-text) !important;
}

html.dark .text-gray-600,
html.dark .text-gray-500,
html.dark .text-neutral-600,
html.dark .text-zinc-600,
html.dark .text-zinc-500,
html.dark .text-slate-600,
html.dark .text-slate-500 {
  color: var(--toolyo-text-faint) !important;
}

html.dark .border-gray-100,
html.dark .border-gray-200,
html.dark .border-gray-300,
html.dark .border-neutral-100,
html.dark .border-neutral-200,
html.dark .border-zinc-100,
html.dark .border-zinc-200,
html.dark .border-zinc-300,
html.dark .border-slate-100,
html.dark .border-slate-200,
html.dark .border-slate-300 {
  border-color: var(--toolyo-border) !important;
}

/* LIGHT MODE overrides for common dark classes */
html:not(.dark) .bg-black,
html:not(.dark) .bg-gray-900,
html:not(.dark) .bg-gray-950,
html:not(.dark) .bg-neutral-900,
html:not(.dark) .bg-neutral-950,
html:not(.dark) .bg-zinc-900,
html:not(.dark) .bg-zinc-950,
html:not(.dark) .bg-slate-900,
html:not(.dark) .bg-slate-950 {
  background-color: var(--toolyo-surface) !important;
}

html:not(.dark) .text-white,
html:not(.dark) .text-gray-50,
html:not(.dark) .text-neutral-50,
html:not(.dark) .text-zinc-50,
html:not(.dark) .text-slate-50 {
  color: var(--toolyo-text) !important;
}

html:not(.dark) .border-gray-700,
html:not(.dark) .border-gray-800,
html:not(.dark) .border-gray-900,
html:not(.dark) .border-neutral-700,
html:not(.dark) .border-neutral-800,
html:not(.dark) .border-zinc-700,
html:not(.dark) .border-zinc-800,
html:not(.dark) .border-zinc-900,
html:not(.dark) .border-slate-700,
html:not(.dark) .border-slate-800,
html:not(.dark) .border-slate-900 {
  border-color: var(--toolyo-border) !important;
}

/* Common specific fixes */
html.dark button,
html.dark a[class*="rounded"] {
  color: var(--toolyo-text) !important;
}

html:not(.dark) button,
html:not(.dark) a[class*="rounded"] {
  color: var(--toolyo-text) !important;
}

html.dark button[class*="bg-black"],
html.dark button[class*="bg-gray-900"],
html.dark button[class*="bg-zinc-900"],
html.dark button[class*="bg-slate-900"],
html.dark a[class*="bg-black"],
html.dark a[class*="bg-gray-900"],
html.dark a[class*="bg-zinc-900"],
html.dark a[class*="bg-slate-900"] {
  background-color: var(--toolyo-surface-2) !important;
}

html:not(.dark) button[class*="bg-white"],
html:not(.dark) a[class*="bg-white"] {
  background-color: var(--toolyo-surface) !important;
}

/* Menu button / icon buttons */
button[class*="h-10"],
button[class*="h-11"],
button[class*="h-12"],
button[class*="w-10"],
button[class*="w-11"],
button[class*="w-12"],
button[class*="p-2"],
button[class*="p-3"] {
  background-color: var(--toolyo-surface) !important;
  color: var(--toolyo-text) !important;
  border-color: var(--toolyo-border) !important;
}

button svg,
a svg {
  color: var(--toolyo-text) !important;
  stroke: var(--toolyo-text) !important;
}

/* Ad slot text */
.toolyo-ad-label,
.toolyo-ad-title {
  color: var(--toolyo-text-faint) !important;
}

/* Strong fallback for any hardcoded inline-ish utility mixes */
html.dark [class*="bg-white/"],
html.dark [class*="bg-gray-"],
html.dark [class*="bg-slate-"],
html.dark [class*="bg-zinc-"] {
  background-color: var(--toolyo-surface) !important;
}

html.dark [class*="text-gray-"],
html.dark [class*="text-slate-"],
html.dark [class*="text-zinc-"],
html.dark [class*="text-neutral-"] {
  color: var(--toolyo-text) !important;
}

html.dark [class*="border-gray-"],
html.dark [class*="border-slate-"],
html.dark [class*="border-zinc-"],
html.dark [class*="border-neutral-"] {
  border-color: var(--toolyo-border) !important;
}

html:not(.dark) [class*="bg-black"],
html:not(.dark) [class*="bg-gray-9"],
html:not(.dark) [class*="bg-zinc-9"],
html:not(.dark) [class*="bg-slate-9"],
html:not(.dark) [class*="bg-neutral-9"] {
  background-color: var(--toolyo-surface) !important;
}

html:not(.dark) [class*="text-white"] {
  color: var(--toolyo-text) !important;
}

html:not(.dark) [class*="border-gray-7"],
html:not(.dark) [class*="border-gray-8"],
html:not(.dark) [class*="border-gray-9"],
html:not(.dark) [class*="border-zinc-7"],
html:not(.dark) [class*="border-zinc-8"],
html:not(.dark) [class*="border-zinc-9"],
html:not(.dark) [class*="border-slate-7"],
html:not(.dark) [class*="border-slate-8"],
html:not(.dark) [class*="border-slate-9"] {
  border-color: var(--toolyo-border) !important;
}

@media (prefers-reduced-motion: reduce) {
  html,
  body,
  html.theme-animate *,
  html.theme-animate *::before,
  html.theme-animate *::after {
    transition: none !important;
  }
}

/* TOOLYO_FINAL_THEME_RESET_END */

